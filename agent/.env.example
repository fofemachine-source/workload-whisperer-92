# ============================================
# Configuração do Agente SSRS MineOPS
# ============================================

# URL do ReportServer (sem barra no fim)
SSRS_URL=http://192.168.17.15/ReportServer

# Caminho do relatório no SSRS (URL-encoded automaticamente pelo agente)
SSRS_REPORT_PATH=/JMineOPS/Relatorios_HOMOLOGACAO/Producao Diaria

# Credenciais NTLM (Windows Authentication)
SSRS_USERNAME=DOMINIO\\usuario
SSRS_PASSWORD=sua_senha_aqui
SSRS_DOMAIN=DOMINIO
SSRS_WORKSTATION=

# Intervalo de sincronização em segundos (mínimo 60)
SYNC_INTERVAL=300

# Endpoint Lovable Cloud (não alterar)
INGEST_URL=https://wylcqazlxytrgsoaunni.supabase.co/functions/v1/ingest-mineops

# Token gerado no painel /admin/ssrs
AGENT_TOKEN=mop_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Identificação deste agente (aparece no painel de status)
AGENT_NAME=agente-servidor-mina-01