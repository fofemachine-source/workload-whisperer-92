# ============================================
# Configuração do Agente SSRS MineOPS
# ============================================

# URL do ReportServer (sem barra no fim)
SSRS_URL=http://192.168.17.15/ReportServer

# Caminho do relatório no SSRS
SSRS_REPORT_PATH=/JMineOPS/Relatorios_HOMOLOGAÇÃO/Produção Diária

# Credenciais NTLM (Windows Authentication)
SSRS_USERNAME=
SSRS_PASSWORD=
SSRS_DOMAIN=
SSRS_WORKSTATION=

# Intervalo de sincronização em segundos (mínimo 60)
SYNC_INTERVAL=300

# URL do Supabase
SUPABASE_URL=https://wylcqazlxytrgsoaunni.supabase.co

# Service Role Key do Supabase (manter em branco para preenchimento manual)
SUPABASE_SERVICE_ROLE_KEY=

# Token de autenticação do agente
AGENT_TOKEN=UEM_MINEOPS_2026

# Porta do agente
PORT=3000

# Identificação deste agente (aparece no painel de status)
AGENT_NAME=agente-servidor-mina-01
